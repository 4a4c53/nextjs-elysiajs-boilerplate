{
	"name": "nextjs-elysiajs-boilerplate",
	"version": "0.0.1",
	"description": "Production-ready Next.js boilerplate with Elysia.js, Auth, PostgreSQL, and shadcn/ui dashboard with sidebar",
	"private": true,
	"packageManager": "bun@1.3.12",
	"author": {
		"name": "José Luis Silva",
		"email": "joseluis@4a4c53.com",
		"url": "http://4a4c53.com"
	},
	"config": {
		"postgres_db": "app_db",
		"postgres_user": "app_db_user",
		"postgres_password": "app_db_pass"
	},
	"scripts": {
		"dev": "bun --bun next dev",
		"build": "bun --bun next build",
		"start": "bun --bun next start",
		"lint": "biome check",
		"format": "biome check --write",
		"env:init": "bun run ./scripts/env-init.ts",
		"db:up": "docker compose -f docker/compose.dev.yml up -d",
		"db:down": "docker compose -f docker/compose.dev.yml down",
		"auth:generate": "bunx --bun auth@latest generate --config ./src/core/auth/server.ts",
		"auth:migrate": "bunx --bun auth@latest migrate --config ./src/core/auth/server.ts"
	},
	"ignoreScripts": [
		"sharp",
		"unrs-resolver"
	],
	"trustedDependencies": [
		"sharp",
		"unrs-resolver"
	],
	"dependencies": {
		"@base-ui/react": "1.4.0",
		"@elysiajs/eden": "1.4.8",
		"@hookform/resolvers": "5.2.2",
		"@prisma/adapter-pg": "7.7.0",
		"@prisma/client": "7.7.0",
		"@t3-oss/env-nextjs": "0.13.11",
		"@tabler/icons-react": "3.41.1",
		"better-auth": "1.6.3",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"dotenv": "17.4.2",
		"elysia": "1.4.28",
		"next": "16.2.3",
		"next-themes": "0.4.6",
		"pg": "8.20.0",
		"pino": "10.3.1",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"react-hook-form": "7.72.1",
		"server-only": "0.0.1",
		"shadcn": "4.2.0",
		"sonner": "2.0.7",
		"tailwind-merge": "3.5.0",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@tailwindcss/postcss": "4.2.2",
		"@types/bun": "1.3.12",
		"@types/node": "25.6.0",
		"@types/pg": "8.20.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"pino-pretty": "13.1.3",
		"prisma": "7.7.0",
		"tailwindcss": "4.2.2",
		"tsx": "4.21.0",
		"tw-animate-css": "1.4.0",
		"typescript": "6.0.2"
	}
}
